@{ Layout = null; }
<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <title>Priser – Sparekopi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/nav-footer.css" />
  <link rel="stylesheet" href="/css/hero.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/forms.css" />
</head>
<body>
  <nav class="site-nav">
    <a href="/" class="nav-logo"><div class="nav-logo-dot"></div>Sparekopi</a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href="/Home/Tjenester">Tjenester</a></li>
      <li><a href="/Home/Priser">Priser</a></li>
      <li><a href="/Home/OmOss">Om oss</a></li>
      <li><a href="/Home/Kontakt">Kontakt</a></li>
    </ul>
    <a href="/Home/Kontakt" class="nav-cta">Kontakt oss</a>
  </nav>

  <header class="page-hero" data-bg-text="NOK">
    <p class="page-hero-label">Tilpasset & ærlig</p>
    <h1 class="page-hero-title">Våre<br/><em>Priser</em></h1>
  </header>

  <section class="services-section">
    <div class="sec-header">
      <div class="section-tag fade-up">Prising</div>
      <h2 class="section-title fade-up delay-1">Pris etter<br/><em>ditt behov</em></h2>
    </div>

    <div style="max-width:72ch;margin:0 auto 4rem;padding:0 var(--side-padding)">
      <p class="fade-up" style="font-size:var(--fs-lg);color:var(--color-navy);line-height:1.85;margin-bottom:1.5rem">
        Prisen avhenger av hva du trenger — format, antall, papirkvalitet og etterbehandling. Vi setter alltid av tid til å finne den beste løsningen for deg.
      </p>
      <p class="fade-up delay-1" style="font-size:var(--fs-base);color:var(--color-muted);line-height:1.9">
        Ta kontakt med oss så gir vi deg et raskt og uforpliktende tilbud. Mange bestillinger kan vi hjelpe deg med samme dag.
      </p>
    </div>

    <div class="services-grid" style="padding:0 var(--side-padding) 5rem">

      <div class="service-card fade-up" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/digital_print.jpg" alt="Kopiering og trykk" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">01</div>
          <span class="card-num">01</span>
        </div>
        <div class="card-body">
          <h3>Kopiering & Trykk</h3>
          <p>Svart-hvitt og farge — enkeltark til store opplag. Pris varierer etter antall og format.</p>
        </div>
      </div>

      <div class="service-card fade-up delay-1" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/brosjyrer.jpg" alt="Brosjyrer og plakater" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">02</div>
          <span class="card-num">02</span>
        </div>
        <div class="card-body">
          <h3>Brosjyrer & Plakater</h3>
          <p>Fra flyere til storformat-plakater. Vi tilpasser pris etter opplag og ønsket finish.</p>
        </div>
      </div>

      <div class="service-card fade-up delay-2" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/spiralinnbinding.jpg" alt="Innbinding og laminering" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">03</div>
          <span class="card-num">03</span>
        </div>
        <div class="card-body">
          <h3>Innbinding & Laminering</h3>
          <p>Spiral, limrygg, stifting og laminering. Rask levering — ofte samme dag.</p>
        </div>
      </div>

      <div class="service-card fade-up" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/ROLLUP.jpg" alt="Skilt og reklame" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">04</div>
          <span class="card-num">04</span>
        </div>
        <div class="card-body">
          <h3>Skilt & Reklame</h3>
          <p>Roll-ups, bannere, beach flags og vindusdekor. Pris oppgis etter størrelse og materiale.</p>
        </div>
      </div>

      <div class="service-card fade-up delay-1" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/visittkort.jpg" alt="Visittkort og profilmateriell" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">05</div>
          <span class="card-num">05</span>
        </div>
        <div class="card-body">
          <h3>Visittkort & Profilmateriell</h3>
          <p>Profesjonelle visittkort og profileringsprodukter. Mengderabatt fra 100 stk.</p>
        </div>
      </div>

      <div class="service-card fade-up delay-2" style="cursor:default">
        <div class="card-thumb">
          <img src="/assets/images/tskjorter.jpg" alt="Profilklær" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="card-thumb-fallback" style="display:none">06</div>
          <span class="card-num">06</span>
        </div>
        <div class="card-body">
          <h3>Profilklær</h3>
          <p>T-skjorter, caps og mer med logo. Pris oppgis etter antall og type plagg.</p>
        </div>
      </div>

    </div>
  </section>

  <div style="background:var(--color-navy);padding:5rem var(--side-padding);text-align:center">
    <div class="section-tag fade-up" style="margin:0 auto 1.5rem;color:var(--color-gold)">Få et tilbud</div>
    <h2 class="fade-up delay-1" style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.5rem);color:#fff;font-weight:300;line-height:1.2;margin-bottom:1.5rem">
      Vi svarer <em style="font-style:italic">raskt</em>
    </h2>
    <p class="fade-up delay-2" style="color:rgba(255,255,255,0.65);font-size:var(--fs-base);max-width:50ch;margin:0 auto 2.5rem;line-height:1.85">
      Ring oss, send en e-post eller fyll ut kontaktskjemaet — så får du et uforpliktende tilbud tilpasset akkurat ditt behov.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/Home/Kontakt" class="map-btn" style="background:var(--color-gold);color:var(--color-navy)">Send forespørsel →</a>
      <a href="tel:+4747293443" class="map-btn" style="background:transparent;border:1px solid rgba(255,255,255,0.35);color:#fff">Ring 47 29 34 43</a>
    </div>
  </div>

  <div class="map-strip">
    <div>
      <div class="map-tag">Hvor finner du oss?</div>
      <div class="map-address">Torggata 17B, 2. etasje, Oslo</div>
      <div class="map-sub">Mandag – Fredag: 10:00 – 17:00</div>
    </div>
    <a href="/Home/Kontakt" class="map-btn">Kontakt oss →</a>
  </div>

  <footer class="site-footer">
    <div class="footer-logo"><div class="footer-logo-dot"></div>Sparekopi</div>
    <nav class="footer-links">
      <a href="/Home/Tjenester">Tjenester</a>
      <a href="/Home/Priser">Priser</a>
      <a href="/Home/OmOss">Om oss</a>
      <a href="/Home/Kontakt">Kontakt</a>
    </nav>
    <p class="footer-copy">© 2025 Sparekopi AS · Org.nr: 996 379 418 · Torggata 17B, 0183 Oslo</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
