@model IEnumerable<SparekopiAdmin.Models.ServiceItem>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tjenester – Sparekopi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/nav-footer.css" />
  <link rel="stylesheet" href="/css/hero.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/forms.css" />
</head>
<body>

  <nav class="site-nav">
    <a href="/" class="nav-logo"><div class="nav-logo-dot"></div>Sparekopi</a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href="/Home/Tjenester">Tjenester</a></li>
      <li><a href="/Home/Priser">Priser</a></li>
      <li><a href="/Home/OmOss">Om oss</a></li>
      <li><a href="/Home/Kontakt">Kontakt</a></li>
    </ul>
    <a href="/Home/Kontakt" class="nav-cta">Kontakt oss</a>
  </nav>

  <header class="page-hero" data-bg-text="TRYKK">
    <p class="page-hero-label">Hva vi gjør</p>
    <h1 class="page-hero-title">Våre<br/><em>Tjenester</em></h1>
  </header>

  <div class="marquee-wrapper">
    <div class="marquee-track">
      @foreach (var item in Model)
      {
          <span>@item.Name</span><span class="dot"> ✦ </span>
      }
      @foreach (var item in Model)
      {
          <span>@item.Name</span><span class="dot"> ✦ </span>
      }
    </div>
  </div>

  @{
      var sectionHeadings = new Dictionary<string, string>
      {
          ["Trykk & Kopiering"] = "Alt under<br/><em>ett tak</em>",
          ["Reklame & Skilt"]   = "Bli sett —<br/><em>overalt</em>",
          ["Etterbehandling"]   = "Finish som<br/><em>løfter resultatet</em>",
          ["Profilklær"]        = "Din logo —<br/><em>overalt</em>",
      };
      var sections = Model
          .GroupBy(x => x.Section)
          .OrderBy(g => g.Min(x => x.SortOrder))
          .ToList();
      int sIdx = 0;
  }

  @foreach (var grp in sections)
  {
      string secStyle = sIdx > 0 ? " style=\"padding-top:0\"" : "";
      <section class="services-section"@Html.Raw(secStyle)>
        @if (!string.IsNullOrEmpty(grp.Key))
        {
            <div class="sec-header">
              <div class="section-tag fade-up">@grp.Key</div>
              <h2 class="section-title fade-up delay-1">@Html.Raw(sectionHeadings.GetValueOrDefault(grp.Key, grp.Key))</h2>
            </div>
        }
        <div class="services-grid">
          @foreach (var item in grp.OrderBy(x => x.SortOrder))
          {
              string featPipe = item.Features.Replace("\r\n", "|").Replace("\n", "|");
              string thumbImg = item.ImagePath?.Split('~')[0] ?? "";
              <div class="service-card fade-up"
                   data-modal="item-@item.Id"
                   data-title="@item.Name"
                   data-desc="@item.Description"
                   data-features="@featPipe"
                   data-image="@item.ImagePath">
                <div class="card-thumb">
                  @if (!string.IsNullOrEmpty(thumbImg))
                  {
                      <img src="@thumbImg" alt="@item.Name" loading="lazy"
                           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                      <div class="card-thumb-fallback" style="display:none">@item.SortOrder.ToString("D2")</div>
                  }
                  else
                  {
                      <div class="card-thumb-fallback">@item.SortOrder.ToString("D2")</div>
                  }
                  <span class="card-num">@item.SortOrder.ToString("D2")</span>
                </div>
                <div class="card-body">
                  <h3>@item.Name</h3>
                  <p>@item.ShortDescription</p>
                  <span class="card-hint">Se detaljer →</span>
                </div>
              </div>
          }
        </div>
      </section>
      sIdx++;
  }

  <div class="map-strip">
    <div>
      <div class="map-tag">Klar til å bestille?</div>
      <div class="map-address">Vi svarer raskt</div>
      <div class="map-sub">Ring oss eller send en melding</div>
    </div>
    <a href="/Home/Kontakt" class="map-btn">Kontakt oss →</a>
  </div>

  <footer class="site-footer">
    <div class="footer-logo"><div class="footer-logo-dot"></div>Sparekopi</div>
    <nav class="footer-links">
      <a href="/Home/Tjenester">Tjenester</a>
      <a href="/Home/Priser">Priser</a>
      <a href="/Home/OmOss">Om oss</a>
      <a href="/Home/Kontakt">Kontakt</a>
    </nav>
    <p class="footer-copy">© 2025 Sparekopi AS · Org.nr: 996 379 418 · Torggata 17B, 0183 Oslo</p>
  </footer>

  <!-- MODAL -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modal">
      <button class="modal-close" id="modalClose">✕</button>
      <div id="modalImageWrap"></div>
      <div class="modal-body">
        <div class="modal-tag">Tjeneste</div>
        <h2 class="modal-title" id="modalTitle"></h2>
        <p class="modal-desc" id="modalDesc"></p>
        <div class="modal-features" id="modalFeatures"></div>
        <a href="/Home/Kontakt" class="modal-cta">Be om tilbud →</a>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    const overlay  = document.getElementById('modalOverlay');
    const closeBtn = document.getElementById('modalClose');
    const imgWrap  = document.getElementById('modalImageWrap');
    const titleEl  = document.getElementById('modalTitle');
    const descEl   = document.getElementById('modalDesc');
    const featEl   = document.getElementById('modalFeatures');

    document.querySelectorAll('.service-card[data-modal]').forEach(card => {
      card.addEventListener('click', () => {
        titleEl.textContent = card.dataset.title || '';
        descEl.textContent  = card.dataset.desc  || '';
        const imgs = (card.dataset.image || '').split('~').filter(Boolean);
        const num = card.querySelector('.card-num')?.textContent || '';
        if (imgs.length > 1) {
          imgWrap.innerHTML = `<div style="display:flex;gap:6px">${imgs.map(src =>
            `<img class="modal-image" style="width:50%;object-fit:cover" src="${src}" alt="${card.dataset.title}"
              onerror="this.style.display='none'" />`).join('')}</div>`;
        } else if (imgs.length === 1) {
          imgWrap.innerHTML = `<img class="modal-image" src="${imgs[0]}" alt="${card.dataset.title}"
            onerror="this.parentElement.innerHTML='<div class=modal-image-placeholder>${num}</div>'" />`;
        } else {
          imgWrap.innerHTML = `<div class="modal-image-placeholder">${num}</div>`;
        }
        featEl.innerHTML = (card.dataset.features || '')
          .split('|').map(f => `<div class="modal-feature">${f.trim()}</div>`).join('');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeModal() { overlay.classList.remove('open'); document.body.style.overflow = ''; }
    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>

</body>
</html>
