  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-tag fade-up">Trykkeri & Kopiering — Oslo sentrum</div>
      <h1 class="hero-title fade-up delay-1">Kvalitet<br/>som <em>varer</em><br/><strong>siden 1997</strong></h1>
      <p class="hero-sub fade-up delay-2">Toppmoderne trykkeri midt i Oslo. Vi leverer trykk, kopiering og reklamemateriell med nesten tre tiår daglig erfaring bak oss.</p>
      <div class="hero-actions fade-up delay-3">
        <a href="/Home/Kontakt" class="btn-gold">Send forespørsel →</a>
        <a href="/Home/Tjenester" class="btn-ghost">Se tjenester</a>
      </div>
      <div class="hero-stats fade-up delay-4">
        <div><span class="stat-num">27+</span><div class="stat-label">Års erfaring</div></div>
        <div><span class="stat-num">Oslo</span><div class="stat-label">Sentrum</div></div>
        <div><span class="stat-num">∞</span><div class="stat-label">Fornøyde kunder</div></div>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-graphic">
        <div class="hg-ring r1"></div>
        <div class="hg-ring r2"></div>
        <div class="hg-year-bg">1997</div>
        <div class="info-pills">
          <div class="pill"><span class="pill-label">Adresse</span><span class="pill-val">Torggata 17B</span><div class="pill-dot"></div></div>
          <div class="pill"><span class="pill-label">Etasje</span><span class="pill-val">2. etasje</span><div class="pill-dot"></div></div>
          <div class="pill"><span class="pill-label">Åpent</span><span class="pill-val">Man–Fre 10–17</span><div class="pill-dot"></div></div>
          <div class="pill"><span class="pill-label">Telefon</span><span class="pill-val">47 29 34 43</span><div class="pill-dot"></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="marquee-wrapper">
    <div class="marquee-track">
      @foreach (var name in (IEnumerable<string>)ViewBag.ServiceNames)
      {
          <span>@name</span><span class="dot"> ✦ </span>
      }
      @foreach (var name in (IEnumerable<string>)ViewBag.ServiceNames)
      {
          <span>@name</span><span class="dot"> ✦ </span>
      }
    </div>
  </div>

  <!-- TJENESTER -->
  <section class="services-section">
    <div class="sec-header">
      <div class="section-tag fade-up">Hva vi tilbyr</div>
      <h2 class="section-title fade-up delay-1">Tjenester som<br/><em>gjør inntrykk</em></h2>
    </div>
    <div class="services-grid">

      <div class="service-card fade-up" data-modal="brosjyrer" data-title="Brosjyrer & Digitalt trykk" data-desc="Vi trykker profesjonelle brosjyrer og markedsmateriell i høy kvalitet. Enten det er en enkel folder eller en flersiders katalog — vi leverer skarpe farger og presis detalj hver gang." data-features="Enkelt- og trefoldede brosjyrer|Kataloger opp til 100+ sider|A4, A5 og egendefinerte formater|Matt eller blank finish|Mengderabatt fra 100 stk|Rask levering" data-image="/assets/images/brosjyrer.jpg">
        <div class="card-thumb"><img src="/assets/images/brosjyrer.jpg" alt="Digitalt trykk" loading="lazy" /><span class="card-num">01</span></div>
        <div class="card-body"><h3>Digitalt trykk</h3><p>Rask og presis utskrift i høy kvalitet — fra enkeltark til store opplag.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

      <div class="service-card fade-up delay-1" data-modal="flyer" data-title="Flyere & Kopiering" data-desc="Profesjonelle flyere og rask kopiering i svart-hvitt og farge. Vi kopierer dokumenter og bilder effektivt med nøyaktig fargegjengivelse." data-features="Svart-hvitt og farge|A4, A3 og storformat|Enkelt- og dobbeltsidig|Mengderabatt|Rask utlevering" data-image="/assets/images/flyer.jpg">
        <div class="card-thumb"><img src="/assets/images/flyer.jpg" alt="Flyere & Kopiering" loading="lazy" /><span class="card-num">02</span></div>
        <div class="card-body"><h3>Flyere & Kopiering</h3><p>Profesjonelle flyere og rask kopiering i svart-hvitt og farge.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

      <div class="service-card fade-up delay-2" data-modal="reklame" data-title="Roll-ups, Bannere & Reklameskilt" data-desc="Vi produserer roll-ups, bannere, kundestoppere, veggdekorasjon og vindusdekor. Se eksempler på ekte oppdrag vi har levert — alt fra salonger til butikker i Oslo." data-features="Roll-ups i alle størrelser|Bannere og kundestoppere|Veggdekorasjon storformat|Vindusdekor og skilt|Beach flags / flaggstenger|Klar på 1–3 virkedager" data-image="/assets/images/skilt.jpg">
        <div class="card-thumb"><img src="/assets/images/skilt.jpg" alt="Roll-ups & Reklame" loading="lazy" /><span class="card-num">03</span></div>
        <div class="card-body"><h3>Roll-ups & Reklame</h3><p>Plakater, bannere, skilt og veggdekor. Vi hjelper deg å bli sett.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

      <div class="service-card fade-up" data-modal="visittkort" data-title="Visittkort" data-desc="Profesjonelle visittkort i ulike formater og papirkvaliteter. Gjør det riktige inntrykket — hver eneste gang du møter noen nytt." data-features="Standard 85x55mm|350g og 400g papirkvalitet|Matt eller blank laminering|Ensidig og tosidig trykk|Avrundede hjørner tilgjengelig|Fra 100 stk" data-image="/assets/images/visittkort.jpg">
        <div class="card-thumb"><img src="/assets/images/visittkort.jpg" alt="Visittkort" loading="lazy" /><span class="card-num">04</span></div>
        <div class="card-body"><h3>Visittkort</h3><p>Profesjonelle visittkort i ulike formater og papirkvaliteter.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

      <div class="service-card fade-up delay-1" data-modal="innbinding" data-title="Innbinding" data-desc="Vi binder inn rapporter, oppgaver, presentasjoner og manualer profesjonelt og raskt. Med spiralinnbinding eller limrygg får dokumentet ditt et solid og ryddig uttrykk." data-features="Plastspiral og metallspiral|Limrygsbinding|Stifting for tynnere hefter|Inkluderer for- og bakside|Opp til 400 sider|Rask utlevering — ofte samme dag" data-image="/assets/images/banner.jpg">
        <div class="card-thumb"><img src="/assets/images/banner.jpg" alt="Innbinding" loading="lazy" /><span class="card-num">05</span></div>
        <div class="card-body"><h3>Innbinding</h3><p>Spiral, limrygg og stifting — rapporter bundet profesjonelt.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

      <div class="service-card fade-up delay-2" data-modal="laminering" data-title="Laminering & Menyer" data-desc="Laminering beskytter trykket ditt mot fukt, søl og slitasje — perfekt for menyer, prislister, sertifikater og skilt som skal tåle daglig bruk." data-features="Matt og blank laminering|A4, A3 og egendefinerte størrelser|Enkelt- og dobbeltsidig|Perfekt for restaurantmenyer|Beskytter mot fukt og flekker" data-image="/assets/images/meny.jpg">
        <div class="card-thumb"><img src="/assets/images/meny.jpg" alt="Laminering & Menyer" loading="lazy" /><span class="card-num">06</span></div>
        <div class="card-body"><h3>Laminering & Menyer</h3><p>Matt eller blank laminering — perfekt for menyer og sertifikater.</p><span class="card-hint">Se detaljer →</span></div>
      </div>

    </div>
  </section>

