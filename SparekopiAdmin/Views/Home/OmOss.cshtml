@{ Layout = null; }
<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <title>Om oss – Sparekopi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../css/variables.css" />
  <link rel="stylesheet" href="../css/base.css" />
  <link rel="stylesheet" href="../css/nav-footer.css" />
  <link rel="stylesheet" href="../css/hero.css" />
  <link rel="stylesheet" href="../css/components.css" />
  <link rel="stylesheet" href="../css/forms.css" />
</head>
<body>
  <nav class="site-nav">
    <a href="/" class="nav-logo"><img src="/assets/images/logo-sparekopi.png" alt="Sparekopi" class="nav-logo-img" height="48" /></a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href="/Home/Tjenester">Tjenester</a></li><li><a href="/Home/Priser">Priser</a></li>
      <li><a href="/Home/OmOss">Om oss</a></li><li><a href="/Home/Kontakt">Kontakt</a></li>
    </ul>
    <a href="/Home/Kontakt" class="nav-cta">Kontakt oss</a>
  </nav>

  <header class="page-hero" data-bg-text="1997">
    <p class="page-hero-label">Vår historie</p>
    <h1 class="page-hero-title">Om<br/><em>Sparekopi</em></h1>
  </header>

  <section class="about-section">
    <div class="fade-up">
      <div class="about-label">Hvem er vi?</div>
      <h2 class="about-heading">Siden 1997 —<br/><em>alltid i forkant</em></h2>
      <p class="about-body">Sparekopi ble stiftet i 1997 og ligger midt i Oslo sentrum på Torggata 17B — rett ovenfor Pascal. Vi har toppmoderne maskinpark og de nyeste maskinene innen moderne teknologi.<br/><br/>Med snart tre tiår daglig erfaring kan vi gjøre de fleste jobber innen reklamer, kopiering og trykk. Vi jobber side om side med alt fra store bedrifter til studenter og privatpersoner.</p>
      <div class="stats-row">
        <div><span class="stat-num">1997</span><div class="stat-label">Etablert</div></div>
        <div><span class="stat-num">27+</span><div class="stat-label">Års erfaring</div></div>
        <div><span class="stat-num">∞</span><div class="stat-label">Fornøyde kunder</div></div>
      </div>
    </div>
    <div class="about-right fade-up delay-2">
      <div class="about-card"><div class="about-card-label">Adresse</div><div class="about-card-val">Torggata 17B, 2. etasje<br/>0183 Oslo</div></div>
      <div class="about-card"><div class="about-card-label">Telefon</div><div class="about-card-val">@ViewBag.Phone</div></div>
      <div class="about-card"><div class="about-card-label">Åpningstider</div><div class="about-card-val">@ViewBag.OpeningHours</div></div>
    </div>
  </section>

  <section class="timeline">
    <div class="section-tag fade-up" style="color:var(--color-gold2)">Vår reise</div>
    <h2 class="section-title fade-up delay-1" style="color:#fff;margin-bottom:0">Fra oppstart<br/><em>til i dag</em></h2>
    <div class="timeline-items">
      <div class="timeline-item fade-up"><div class="timeline-year">1997</div><div class="timeline-title">Sparekopi åpner dørene</div><p class="timeline-desc">Vi starter som en liten kopieringsbutikk midt i Oslo sentrum med ett mål: god service til riktig pris.</p></div>
      <div class="timeline-item fade-up"><div class="timeline-year">2003</div><div class="timeline-title">Digitalt trykk inntog</div><p class="timeline-desc">Vi investerer i den første digitale trykkmaskin og kan nå levere profesjonell kvalitet på kort tid.</p></div>
      <div class="timeline-item fade-up"><div class="timeline-year">2010</div><div class="timeline-title">Sparekopi AS stiftes</div><p class="timeline-desc">Virksomheten omstruktureres som aksjeselskap. Vi utvider maskinparken og tilbyr full service innen trykk.</p></div>
      <div class="timeline-item fade-up"><div class="timeline-year">2020+</div><div class="timeline-title">Alltid i fremste rekke</div><p class="timeline-desc">Vi fornyer jevnlig utstyret og holder oss oppdatert på den nyeste teknologien.</p></div>
    </div>
  </section>

  <section class="services-section">
    <div class="sec-header"><div class="section-tag fade-up">Våre verdier</div><h2 class="section-title fade-up delay-1">Det vi<br/><em>tror på</em></h2></div>
    <div class="values-grid">
      <div class="value-card fade-up"><div class="value-num">01</div><h3 class="value-title">Kvalitet</h3><p class="value-desc">Vi bruker toppmoderne utstyr og tar aldri snarveier. Hvert oppdrag fortjener det beste resultatet vi kan levere.</p></div>
      <div class="value-card fade-up delay-1"><div class="value-num">02</div><h3 class="value-title">Rask levering</h3><p class="value-desc">Vi vet at tid er penger. Vi jobber effektivt og leverer raskt — uten at det går ut over kvaliteten.</p></div>
      <div class="value-card fade-up"><div class="value-num">03</div><h3 class="value-title">Ærlig pris</h3><p class="value-desc">Ingen skjulte gebyrer. Du får alltid et klart og ærlig tilbud før vi starter jobben.</p></div>
      <div class="value-card fade-up delay-1"><div class="value-num">04</div><h3 class="value-title">Personlig service</h3><p class="value-desc">Vi er et lite team som bryr oss. Du møter ekte mennesker som lytter og finner den beste løsningen.</p></div>
    </div>
  </section>

  <div class="map-strip">
    <div><div class="map-tag">Besøk oss</div><div class="map-address">Torggata 17B, Oslo</div><div class="map-sub">2. etasje · Man–Fre 10–17</div></div>
    <a href="https://maps.google.com/?q=Torggata+17B,+0183+Oslo" target="_blank" rel="noopener" class="map-btn">Åpne Google Maps →</a>
  </div>

  <footer class="site-footer">
    <div class="footer-logo"><div class="footer-logo-dot"></div>Sparekopi</div>
    <nav class="footer-links"><a href="/Home/Tjenester">Tjenester</a><a href="/Home/Priser">Priser</a><a href="/Home/OmOss">Om oss</a><a href="/Home/Kontakt">Kontakt</a></nav>
    <p class="footer-copy">© 2025 Sparekopi AS · Org.nr: 996 379 418 · Torggata 17B, 0183 Oslo</p>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>
