<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Sparekopi Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f0; }
        a { text-decoration: none; }

        /* ── SIDEBAR ── */
        .admin-sidebar { width: 220px; background: #18181b; color: #fff; flex-shrink: 0; display: flex; flex-direction: column; position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; }
        .sidebar-brand { padding: 18px 16px; font-size: 1rem; font-weight: 700; letter-spacing: 0.03em; border-bottom: 1px solid #27272a; display: flex; align-items: center; gap: 8px; }
        .brand-dot { width: 8px; height: 8px; background: #c9a96e; border-radius: 50%; flex-shrink: 0; }
        .sidebar-nav { flex: 1; padding: 10px 0; overflow-y: auto; }
        .nav-section { padding: 14px 16px 4px; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #52525b; font-weight: 600; }
        .sidebar-link { display: flex; align-items: center; gap: 10px; padding: 9px 16px; color: #a1a1aa; font-size: 0.875rem; transition: background 0.12s, color 0.12s; }
        .sidebar-link:hover { background: #27272a; color: #e4e4e7; }
        .sidebar-link.active { background: #27272a; color: #fff; border-left: 2px solid #c9a96e; padding-left: 14px; }
        .sidebar-footer { padding: 10px 0; border-top: 1px solid #27272a; }

        /* ── MAIN ── */
        .admin-wrap { display: flex; min-height: 100vh; }
        .admin-main { margin-left: 220px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
        .admin-header { background: #fff; border-bottom: 1px solid #e4e4e7; padding: 0 32px; height: 54px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; }
        .header-title { font-size: 0.9375rem; font-weight: 600; color: #18181b; margin: 0; }
        .admin-body { padding: 32px; }

        /* ── CARDS ── */
        .stat-card { background: #fff; border: 1px solid #e4e4e7; border-radius: 8px; padding: 20px 24px; }
        .stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: #71717a; font-weight: 600; margin-bottom: 6px; }
        .stat-number { font-size: 2rem; font-weight: 700; color: #18181b; line-height: 1; }
        .action-card { background: #fff; border: 1px solid #e4e4e7; border-radius: 8px; padding: 24px; height: 100%; display: flex; flex-direction: column; }
        .action-card h3 { font-size: 1rem; font-weight: 600; color: #18181b; margin: 0 0 8px; }
        .action-card p { font-size: 0.875rem; color: #71717a; line-height: 1.5; margin: 0 0 auto; padding-bottom: 20px; }
        .content-card { background: #fff; border: 1px solid #e4e4e7; border-radius: 8px; padding: 28px; }
        .content-card-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #71717a; font-weight: 600; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid #f4f4f5; }

        /* ── FORMS ── */
        .form-label { font-size: 0.8125rem; font-weight: 500; color: #3f3f46; margin-bottom: 5px; }
        .form-control, .form-select { border: 1px solid #e4e4e7; border-radius: 6px; font-size: 0.875rem; padding: 8px 12px; }
        .form-control:focus, .form-select:focus { border-color: #c9a96e; box-shadow: 0 0 0 3px rgba(201,169,110,0.12); outline: none; }
        .form-text { font-size: 0.75rem; color: #71717a; margin-top: 4px; }
        .btn-save { background: #18181b; color: #fff; border: none; padding: 10px 22px; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; display: inline-block; }
        .btn-save:hover { background: #27272a; color: #fff; }

        /* ── TABLE ── */
        .table thead th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: #71717a; font-weight: 600; border-bottom: 1px solid #e4e4e7 !important; padding: 10px 16px !important; background: #fafafa; }
        .table tbody td { padding: 14px 16px !important; vertical-align: middle; font-size: 0.875rem; border-bottom: 1px solid #f4f4f5 !important; }
        .table tbody tr:last-child td { border-bottom: none !important; }
        .table tbody tr:hover td { background: #fafafa; }

        /* ── ALERT ── */
        .flash-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: 6px; font-size: 0.8125rem; padding: 8px 14px; }
    </style>
</head>
<body>
    @{
        var _ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var _act  = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        string SA(string c, string a = "") =>
            _ctrl == c && (string.IsNullOrEmpty(a) || _act == a) ? " active" : "";
    }
    <div class="admin-wrap">
        <nav class="admin-sidebar">
            <div class="sidebar-brand">
                <span class="brand-dot"></span>Sparekopi
            </div>
            <div class="sidebar-nav">
                <a asp-controller="Admin" asp-action="Index" class="sidebar-link@(SA("Admin","Index"))">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                    Dashboard
                </a>
                <div class="nav-section">Nettstedinnhold</div>
                <a asp-controller="Admin" asp-action="Kontaktinfo" class="sidebar-link@(SA("Admin","Kontaktinfo"))">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.11 19.79 19.79 0 01.22 2.41 2 2 0 012.22.39h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.06 6.06l1.59-1.59a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                    Kontaktinfo
                </a>
                <a asp-controller="Admin" asp-action="Forside" class="sidebar-link@(SA("Admin","Forside"))">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Forside-tekst
                </a>
                <div class="nav-section">Tjenester & Priser</div>
                <a href="/ServiceItems?category=tjeneste" class="sidebar-link@(_ctrl=="ServiceItems" && ViewContext.HttpContext.Request.Query["category"]=="tjeneste" ? " active" : "")">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                    Tjenester
                </a>
                <a href="/ServiceItems?category=pris" class="sidebar-link@(_ctrl=="ServiceItems" && ViewContext.HttpContext.Request.Query["category"]=="pris" ? " active" : "")">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    Priser
                </a>
            </div>
            <div class="sidebar-footer">
                <a href="/Home/Index" target="_blank" class="sidebar-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Se nettside
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-link" style="color:#ef4444;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logg ut
                </a>
            </div>
        </nav>

        <div class="admin-main">
            <header class="admin-header">
                <h1 class="header-title">@(ViewData["PageTitle"] ?? ViewData["Title"])</h1>
                @if (TempData["Success"] != null)
                {
                    <div class="flash-success">✓ @TempData["Success"]</div>
                }
            </header>
            <div class="admin-body">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
