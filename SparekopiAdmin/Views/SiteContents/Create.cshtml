@model SparekopiAdmin.Models.SiteContent

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nytt innholdselement";
    ViewData["PageTitle"] = "Nytt innholdselement";
}

<div style="max-width:560px;">
    <div class="content-card">
        <div class="content-card-title">Ny verdi</div>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:0.8125rem;"></div>
            <div class="mb-3">
                <label asp-for="Key" class="form-label">Nøkkel</label>
                <input asp-for="Key" class="form-control" style="font-family:monospace;" />
                <span asp-validation-for="Key" class="text-danger" style="font-size:0.8125rem;"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Value" class="form-label">Verdi</label>
                <textarea asp-for="Value" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Value" class="text-danger" style="font-size:0.8125rem;"></span>
            </div>
            <div style="display:flex;gap:14px;align-items:center;">
                <button type="submit" class="btn-save">Lagre</button>
                <a asp-action="Index" style="font-size:0.875rem;color:#71717a;">Avbryt</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
