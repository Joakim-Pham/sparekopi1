@model SparekopiAdmin.Models.SiteContent

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Innholdselement";
    ViewData["PageTitle"] = Model.Key;
}

<div style="max-width:460px;">
    <div class="content-card">
        <dl style="font-size:0.875rem;">
            <dt class="stat-label">Nøkkel</dt>
            <dd style="font-family:monospace;font-size:1rem;font-weight:600;color:#18181b;margin-bottom:18px;">@Model.Key</dd>
            <dt class="stat-label">Verdi</dt>
            <dd style="color:#3f3f46;white-space:pre-wrap;margin:0;">@Model.Value</dd>
        </dl>
        <div style="margin-top:24px;padding-top:18px;border-top:1px solid #f4f4f5;display:flex;gap:14px;align-items:center;">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-save">Rediger</a>
            <a asp-action="Index" style="font-size:0.875rem;color:#71717a;">Tilbake til liste</a>
        </div>
    </div>
</div>
