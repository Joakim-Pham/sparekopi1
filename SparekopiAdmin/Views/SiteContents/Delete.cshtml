@model SparekopiAdmin.Models.SiteContent

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Slett innhold";
    ViewData["PageTitle"] = "Slett innholdselement";
}

<div style="max-width:460px;">
    <div class="content-card">
        <div class="content-card-title" style="color:#ef4444;">Bekreft sletting</div>
        <p style="font-size:0.875rem;color:#3f3f46;margin-bottom:20px;">
            Er du sikker på at du vil slette dette innholdselementet? Dette kan ikke angres.
        </p>
        <dl style="font-size:0.875rem;background:#fafafa;border:1px solid #f4f4f5;border-radius:6px;padding:16px;margin-bottom:24px;">
            <dt style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.07em;color:#71717a;font-weight:600;margin-bottom:4px;">Nøkkel</dt>
            <dd style="font-family:monospace;font-weight:600;color:#18181b;margin-bottom:12px;">@Model.Key</dd>
            <dt style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.07em;color:#71717a;font-weight:600;margin-bottom:4px;">Verdi</dt>
            <dd style="color:#3f3f46;margin:0;">@Model.Value</dd>
        </dl>
        <form asp-action="Delete" style="display:flex;gap:14px;align-items:center;">
            <input type="hidden" asp-for="Id" />
            <button type="submit"
                    style="background:#ef4444;color:#fff;border:none;padding:10px 22px;border-radius:6px;font-size:0.875rem;font-weight:500;cursor:pointer;">
                Slett
            </button>
            <a asp-action="Index" style="font-size:0.875rem;color:#71717a;">Avbryt</a>
        </form>
    </div>
</div>
