@{ Layout = null; }
<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logg inn – Sparekopi Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #18181b; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-box { background: #fff; border-radius: 12px; padding: 40px 36px; width: 100%; max-width: 380px; }
        .brand { display: flex; align-items: center; gap: 8px; font-size: 1.1rem; font-weight: 700; color: #18181b; margin-bottom: 28px; }
        .brand-dot { width: 10px; height: 10px; background: #c9a96e; border-radius: 50%; }
        .brand-sub { font-size: 0.75rem; color: #71717a; font-weight: 400; margin-left: 2px; }
        label { font-size: 0.8125rem; font-weight: 500; color: #3f3f46; display: block; margin-bottom: 5px; }
        input[type=text], input[type=password] { width: 100%; border: 1px solid #e4e4e7; border-radius: 6px; padding: 10px 12px; font-size: 0.875rem; outline: none; transition: border-color 0.15s; }
        input[type=text]:focus, input[type=password]:focus { border-color: #c9a96e; box-shadow: 0 0 0 3px rgba(201,169,110,0.12); }
        .field { margin-bottom: 18px; }
        .btn-login { width: 100%; background: #18181b; color: #fff; border: none; padding: 11px; border-radius: 6px; font-size: 0.9375rem; font-weight: 500; cursor: pointer; margin-top: 6px; }
        .btn-login:hover { background: #27272a; }
        .error-msg { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 6px; padding: 10px 14px; font-size: 0.8125rem; margin-bottom: 18px; }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="brand">
            <span class="brand-dot"></span>
            Sparekopi
            <span class="brand-sub">Admin</span>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" asp-action="Login" asp-controller="Account">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="field">
                <label for="username">Brukernavn</label>
                <input type="text" id="username" name="username" autocomplete="username" autofocus />
            </div>
            <div class="field">
                <label for="password">Passord</label>
                <input type="password" id="password" name="password" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn-login">Logg inn →</button>
        </form>
    </div>
</body>
</html>
