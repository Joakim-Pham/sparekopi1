@model SparekopiAdmin.Models.ServiceItem

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tjeneste — detaljer";
    ViewData["PageTitle"] = Model.Name;
}

<div style="max-width:460px;">
    <div class="content-card">
        <dl style="font-size:0.875rem;">
            <dt class="stat-label">Navn</dt>
            <dd style="font-size:1rem;font-weight:600;color:#18181b;margin-bottom:18px;">@Model.Name</dd>
            <dt class="stat-label">Beskrivelse</dt>
            <dd style="color:#3f3f46;margin-bottom:18px;">@Model.Description</dd>
            <dt class="stat-label">Pris</dt>
            <dd style="font-size:1.125rem;font-weight:700;color:#18181b;margin:0;">
                @if (Model.Price == 0)
                {
                    <span>Pris på forespørsel</span>
                }
                else
                {
                    <span>kr @Model.Price.ToString("N0"),-</span>
                }
            </dd>
        </dl>
        <div style="margin-top:24px;padding-top:18px;border-top:1px solid #f4f4f5;display:flex;gap:14px;align-items:center;">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-save">Rediger</a>
            <a asp-action="Index" style="font-size:0.875rem;color:#71717a;">Tilbake til liste</a>
        </div>
    </div>
</div>
