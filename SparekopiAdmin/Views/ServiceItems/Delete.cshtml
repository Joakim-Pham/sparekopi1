@model SparekopiAdmin.Models.ServiceItem

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Slett tjeneste";
    ViewData["PageTitle"] = "Slett tjeneste";
}

<div style="max-width:460px;">
    <div class="content-card">
        <div class="content-card-title" style="color:#ef4444;">Bekreft sletting</div>
        <p style="font-size:0.875rem;color:#3f3f46;margin-bottom:20px;">
            Er du sikker på at du vil slette <strong>@Model.Name</strong>? Dette kan ikke angres.
        </p>
        <dl style="font-size:0.875rem;background:#fafafa;border:1px solid #f4f4f5;border-radius:6px;padding:16px;margin-bottom:24px;">
            <dt style="font-weight:600;color:#18181b;margin-bottom:4px;">@Model.Name</dt>
            <dd style="color:#71717a;margin-bottom:8px;">@Model.Description</dd>
            <dd style="font-weight:600;margin:0;">
                @if (Model.Price == 0)
                {
                    <span>Pris på forespørsel</span>
                }
                else
                {
                    <span>kr @Model.Price.ToString("N0"),-</span>
                }
            </dd>
        </dl>
        <form asp-action="Delete" style="display:flex;gap:14px;align-items:center;">
            <input type="hidden" asp-for="Id" />
            <button type="submit"
                    style="background:#ef4444;color:#fff;border:none;padding:10px 22px;border-radius:6px;font-size:0.875rem;font-weight:500;cursor:pointer;">
                Slett
            </button>
            <a asp-action="Index" style="font-size:0.875rem;color:#71717a;">Avbryt</a>
        </form>
    </div>
</div>
